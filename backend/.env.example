# Bitrix24 app OAuth credentials (from the app settings in the Bitrix24 dev portal)
CLIENT_ID=your-bitrix24-app-client-id
CLIENT_SECRET=your-bitrix24-app-client-secret
# Where Bitrix24 redirects after authorize (must match the app settings)
REDIRECT_URI=https://your-backend.example.com/auth/callback
# The SPA URL — bound into CRM list menus on install (placement.bind)
APP_HANDLER_URL=https://your-frontend.example.com
# Where Bitrix24 POSTs CRM add-events for auto-merge-on-create (event.bind).
# Defaults to the REDIRECT_URI origin + /events/handler if left unset.
EVENT_HANDLER_URL=https://your-backend.example.com/events/handler

PORT=3000
# Comma-separated origins allowed to call the API (the SPA origin, etc.)
CORS_ORIGIN=https://your-frontend.example.com

# Postgres connection
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bitrix24_dedup
